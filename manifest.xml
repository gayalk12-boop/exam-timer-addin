<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="ContentApp">

  <Id>22334455-6677-8899-aabb-ccddeeff0011</Id>
  <Version>2.0.0.0</Version>
  <ProviderName>gayalk12-boop</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Exam Timer" />
  <Description DefaultValue="A live countdown timer that runs directly on your PowerPoint slide. Perfect for exams and timed sessions." />
  <IconUrl DefaultValue="https://gayalk12-boop.github.io/exam-timer-addin/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://gayalk12-boop.github.io/exam-timer-addin/assets/icon-80.png" />
  <SupportUrl DefaultValue="https://github.com/gayalk12-boop/exam-timer-addin" />

  <AppDomains>
    <AppDomain>https://gayalk12-boop.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Presentation" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Selection" MinVersion="1.1" />
    </Sets>
  </Requirements>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://gayalk12-boop.github.io/exam-timer-addin/timer.html" />
    <RequestedWidth>600</RequestedWidth>
    <RequestedHeight>400</RequestedHeight>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

</OfficeApp>
